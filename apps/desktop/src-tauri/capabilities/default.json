{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main", "vault-*"],
	"permissions": [
		"core:default",
		"core:window:allow-start-dragging",
		"core:window:allow-create",
		"opener:allow-open-path",
		{
			"identifier": "opener:allow-open-path",
			"allow": [{ "path": "**" }]
		},
		"dialog:default"
	]
}
