{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "settings",
	"description": "Capability for the dedicated settings window",
	"windows": ["settings"],
	"permissions": [
		"core:default",
		"opener:allow-reveal-item-in-dir",
		{
			"identifier": "opener:allow-reveal-item-in-dir",
			"allow": [{ "path": "**" }]
		},
		"dialog:default",
		"notification:default"
	]
}
