{
	"name": "cortex",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*",
		"plugins/*"
	],
	"scripts": {
		"dev:desktop": "bun run --cwd apps/desktop tauri dev",
		"dev:web": "bun run --cwd apps/web dev",
		"lint": "biome lint .",
		"lint:fix": "biome lint --fix .",
		"format": "biome format .",
		"format:fix": "biome format --fix .",
		"check": "biome check .",
		"check:fix": "biome check --fix .",
		"typecheck": "tsc -b",
		"test": "bun run --cwd packages/core vitest run && bun run --cwd packages/settings vitest run && bun run --cwd apps/desktop vitest run",
		"test:watch": "vitest",
		"test:coverage": "bun run --cwd packages/core vitest run --coverage && bun run --cwd packages/settings vitest run --coverage && bun run --cwd apps/desktop vitest run --coverage"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@vitest/coverage-v8": "^4.1.0",
		"jsdom": "^29.0.1",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"typescript": "~5.8.3",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@testing-library/dom": "^10.4.1",
		"next-themes": "^0.4.6"
	}
}
