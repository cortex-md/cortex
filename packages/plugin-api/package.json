{
	"name": "cortex-plugin-api",
	"version": "0.1.0",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"prepublishOnly": "bun run build"
	},
	"publishConfig": {
		"access": "public",
		"main": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js"
			}
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/cortex-md/cortex.git",
		"directory": "packages/plugin-api"
	},
	"keywords": [
		"cortex",
		"plugin",
		"api",
		"markdown",
		"editor"
	],
	"devDependencies": {
		"typescript": "~5.8.3"
	}
}
